{
  "name": "private-ai-gateway-executor",
  "version": "0.1.0",
  "description": "Plaintext execution middleware for private-ai-gateway: request shaping, provider format conversion, response/usage handling.",
  "private": true,
  "type": "module",
  "bin": "build/server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "format": "prettier --write \"./src/**/*.ts\"",
    "format:check": "prettier --check \"./src/**/*.ts\""
  },
  "dependencies": {
    "@hono/node-server": "^1.3.3",
    "decimal.js": "^10.6.0",
    "hono": "^4.6.10",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "20.8.3",
    "jest": "^29.7.0",
    "prettier": "3.2.5",
    "ts-jest": "^29.2.4",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
