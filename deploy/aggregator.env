# Runtime config the launcher will export into entrypoint.sh's environment.
#
# These are deployment policy. They are NOT pinned by the launcher's repo /
# commit / subdir trust fields, but they ARE audited by anyone verifying a
# deployment because the aggregator publishes the source-provenance arms in
# its attestation report. Keep this file under the same trust review as the
# launcher .conf next to it (dstack compose-hash, derived image, etc.).
#
# Variable naming uses the PRIVATE_AI_GATEWAY_* prefix.

# Listen address inside the TEE container. Containers should still expose the
# port via compose `ports:`; the aggregator does not do TLS itself yet.
PRIVATE_AI_GATEWAY_BIND=0.0.0.0:8086

# Single upstream config file. Missing or empty means the router starts with no
# upstreams configured. The admin API replaces this same file at runtime.
PRIVATE_AI_GATEWAY_UPSTREAM_CONFIG_PATH=/var/lib/private-ai-gateway/upstreams.json

# Required to enable GET/PUT /v1/admin/upstreams. Leave unset to disable the
# admin config endpoint.
# PRIVATE_AI_GATEWAY_ADMIN_TOKEN=<long-random-admin-token>

# Source-provenance arms surfaced in GET /v1/attestation/report. A verifier
# resolves the public-repo bytes at REPO_COMMIT and confirms that
# entrypoint.sh + the Cargo workspace at that commit produced the binary
# currently running in the TEE.
PRIVATE_AI_GATEWAY_REPO_URL=https://github.com/Dstack-TEE/private-ai-gateway.git
PRIVATE_AI_GATEWAY_REPO_COMMIT=0000000000000000000000000000000000000000

# Optional ACI policy knobs. The default body-retention value is 0, which
# means /v1/receipt/{chat_id}/body returns receipt_body_not_retained.
# Set a nonzero value only when the deployment is prepared to protect the
# retained post-rewrite request bodies.
# PRIVATE_AI_GATEWAY_BODY_RETENTION_SECONDS=0

# Optional global upstream verifier mode. Use aci-dcap only for ACI/dstack
# upstreams, and preverified only during explicit bring-up.
# PRIVATE_AI_GATEWAY_UPSTREAM_VERIFIER=none

# Optional upstream HTTP timeout policy. Connect timeout applies to forwarding
# and upstream attestation fetches. Read timeout is an idle timeout between
# upstream response bytes/chunks, not a total generation deadline. Verifier
# request timeout is the total deadline for upstream ACI/DCAP verification.
# PRIVATE_AI_GATEWAY_UPSTREAM_CONNECT_TIMEOUT_SECONDS=10
# PRIVATE_AI_GATEWAY_UPSTREAM_READ_TIMEOUT_SECONDS=600
# PRIVATE_AI_GATEWAY_UPSTREAM_VERIFIER_REQUEST_TIMEOUT_SECONDS=60

# Optional comma-separated paths to mounted client-facing leaf certificates.
# The aggregator computes SHA-256 over each certificate's SPKI and publishes
# those digests in the attested keyset. Prefer this over manually entering
# SPKI digests because certificate renewal then updates one mounted artifact.
# PRIVATE_AI_GATEWAY_TLS_CERT_PATHS=/etc/tls/aci-endpoint.crt

# Manual/test alternative. Do not set together with
# PRIVATE_AI_GATEWAY_TLS_CERT_PATHS.
# PRIVATE_AI_GATEWAY_TLS_SPKI_SHA256=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# Optional dstack SDK endpoint used for KMS keys and TDX quotes. In production
# the SDK defaults to /var/run/dstack.sock, so this is usually omitted. Local
# development can use an SSH-forwarded CVM socket.
# PRIVATE_AI_GATEWAY_DSTACK_ENDPOINT=unix:/var/run/dstack.sock
# PRIVATE_AI_GATEWAY_DSTACK_ENDPOINT=unix:/tmp/aci-dstack-sock-dev.dstack.sock

# Optional local verifier checkout for provider adapters. The Rust adapter owns
# the verifier call; upstream config does not define commands. Tinfoil and NEAR
# AI use PRIVATE_AI_VERIFIER_DIR when the private-ai-verifier checkout is not a
# sibling of this repo.
#
# Provider credentials and provider-specific tuning belong in the upstream
# config file. For Chutes, set bearer_token, verification_refresh_seconds,
# session_refresh_seconds, chutes_e2ee_api_base,
# chutes_e2ee_discovery_rounds, and
# chutes_e2ee_discovery_interval_seconds there.
# PRIVATE_AI_VERIFIER_DIR=/opt/private-ai-verifier
